    <Paragraph Type="Action">
      <Text>Oh shit, yeah. What the fuck, bro.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Micah</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>I don‚Äôt remember that.</Text>
